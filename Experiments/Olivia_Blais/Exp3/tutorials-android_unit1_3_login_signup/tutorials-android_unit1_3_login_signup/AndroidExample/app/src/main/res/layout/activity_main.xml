<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/my_background_color"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/main_username_txt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="{{username}}"
        android:layout_gravity="center"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="18dp"
        android:textSize="30sp"
        android:textColor="#000000">
    </TextView>

    <TextView
        android:id="@+id/main_msg_txt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="1dp"
        android:layout_marginBottom="1dp"
        android:fontFamily="@font/goldman_bold"
        android:text="Nexus"
        android:textColor="@color/my_text_color"
        android:textSize="100sp"></TextView>


    <TextView
        android:id="@+id/welcome_msg_txt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginHorizontal="50dp"
        android:layout_marginTop="5dp"
        android:layout_marginBottom="40dp"
        android:fontFamily="@font/alef"
        android:text="Get started with the web scraper by logging in or signing up!"
        android:textColor="@color/my_text_color"
        android:textSize="25sp"></TextView>


    <Button
        android:id="@+id/main_login_btn"
        android:layout_width="150dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="Login"
        android:textColor="@color/my_text_color"
        android:backgroundTint="@color/my_button_color"
        android:fontFamily="@font/alef"
        android:textSize="20sp"
        app:iconTint="#4857AD"></Button>

    <Button
        android:id="@+id/main_signup_btn"
        android:layout_width="150dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="Signup"
        android:textColor="@color/my_text_color"
        android:backgroundTint="@color/my_button_color"
        android:fontFamily="@font/alef"
        android:textSize="20sp"></Button>

    <Button
        android:id="@+id/main_terms_btn"
        android:layout_width="150dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="Terms"
        android:textColor="@color/my_text_color"
        android:backgroundTint="@color/my_button_color"
        android:fontFamily="@font/alef"
        android:textSize="20sp"
        app:iconTint="#4857AD"></Button>


</androidx.appcompat.widget.LinearLayoutCompat>