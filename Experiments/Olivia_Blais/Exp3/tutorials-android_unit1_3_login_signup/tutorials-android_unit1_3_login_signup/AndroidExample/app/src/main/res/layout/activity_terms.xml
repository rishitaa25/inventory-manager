        android:text="Nexus"
        android:textColor="@color/my_text_color"
        android:textSize="100sp"
        tools:layout_editor_absoluteX="28dp"
        tools:layout_editor_absoluteY="220dp">

    </TextView>

    </androidx.appcompat.widget.LinearLayoutCompat>