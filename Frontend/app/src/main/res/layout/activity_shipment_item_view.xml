<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient">

    <include
        android:id="@+id/banner"
        layout="@layout/banner"
        app:layout_constraintTop_toTopOf="parent"/>

    <TextView
        android:id="@+id/background"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/background_text"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="100dp"
        android:layout_marginBottom="50dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"/>

    <TextView
        android:id="@+id/item_title"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@drawable/background_text_blue"
        android:gravity="center"
        android:text="Item: N/A"
        android:fontFamily="@font/ptserif_regular"
        android:textColor="@color/im_sky_blue"
        android:textSize="50sp"
        app:layout_constraintEnd_toEndOf="@id/background"
        app:layout_constraintStart_toStartOf="@id/background"
        app:layout_constraintTop_toBottomOf="@id/banner"/>

    <TextView
        android:id="@+id/shipment_item_status_msg"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text=""
        android:textColor="@color/text"
        android:textSize="20sp"
        android:layout_marginTop="50dp"
        app:layout_constraintTop_toBottomOf="@id/item_title"
        app:layout_constraintStart_toStartOf="@id/background"
        app:layout_constraintEnd_toEndOf="@id/background"/>


    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="16dp"
        android:background="@drawable/background_text_solid"
        app:layout_constraintTop_toBottomOf="@id/shipment_item_status_msg"
        app:layout_constraintBottom_toTopOf="@id/button_layout"
        app:layout_constraintStart_toStartOf="@id/background"
        app:layout_constraintEnd_toEndOf="@id/background"
        android:layout_marginHorizontal="15dp"
        android:layout_marginBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ITEM NAME -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Item name"
                android:textStyle="bold"
                android:textSize="20sp"
                android:textColor="@color/text"/>
            <TextView
                android:id="@+id/detail_item_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="N/A"
                android:textSize="25sp"
                android:layout_marginBottom="12dp"/>

            <!-- SHIPPING COMPANY -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Shipping Company"
                android:textStyle="bold"
                android:textSize="20sp"
                android:textColor="@color/text"/>
            <TextView
                android:id="@+id/detail_shipping_co"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="N/A"
                android:textSize="25sp"
                android:layout_marginBottom="12dp"/>

            <!-- SHIPPING LOCATION -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Storage Location"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text"/>
            <TextView
                android:id="@+id/detail_location"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="N/A"
                android:textSize="25sp"
                android:layout_marginBottom="12dp"/>

            <!-- QUANTITY -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quantity"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text"/>
            <TextView
                android:id="@+id/detail_quantity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="25sp"
                android:layout_marginBottom="12dp"/>

            <!-- WEIGHT -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Weight"
                android:textStyle="bold"
                android:textSize="20sp"
                android:textColor="@color/text"/>
            <TextView
                android:id="@+id/detail_weight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="0.0 lbs"
                android:textSize="25sp"
                android:layout_marginBottom="12dp"/>

            <!-- SHIPMENT ID -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Shipment ID"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text"/>
            <TextView
                android:id="@+id/detail_shipment_id"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="#000000"
                android:textSize="25sp"
                android:layout_marginBottom="12dp"/>

            <!-- STORAGE TYPE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Storage Type"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text"/>
            <TextView
                android:id="@+id/detail_storage_type"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ambient"
                android:textSize="25sp"
                android:layout_marginBottom="24dp"/>

        </LinearLayout>
    </ScrollView>



    <LinearLayout
        android:id="@+id/button_layout"
        android:layout_width="0dp"
        android:layout_height="60dp"
        app:layout_constraintStart_toStartOf="@id/background"
        app:layout_constraintEnd_toEndOf="@id/background"
        app:layout_constraintBottom_toBottomOf="@id/background"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@drawable/background_text_solid"
        android:layout_marginHorizontal="50dp"
        android:layout_marginBottom="20dp">

        <!-- Back -->
        <LinearLayout
            android:layout_width="70dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginHorizontal="16dp">

            <ImageView
                android:id="@+id/back_icon"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:clickable="true"
                android:focusable="true"
                android:src="@drawable/ic_back"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Back"
                android:textSize="12sp"
                android:gravity="center"/>
        </LinearLayout>

        <!-- Delete -->
        <LinearLayout
            android:layout_width="70dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginHorizontal="16dp">

            <ImageView
                android:id="@+id/delete_icon"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:clickable="true"
                android:focusable="true"
                android:src="@drawable/ic_delete"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Delete"
                android:textSize="12sp"
                android:gravity="center"/>
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>